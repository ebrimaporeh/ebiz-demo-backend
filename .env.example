# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Supabase PostgreSQL (Transaction Pooler) ─────────────────────────────────
DB_NAME=postgres
DB_USER=postgres.neeuqoqxvmpbbskrxste
DB_PASSWORD=your_supabase_password
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=6543

# ─── Supabase Project ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
# Dashboard → Project Settings → API → service_role  (keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Dashboard → Project Settings → API → anon / public
SUPABASE_ANON_KEY=your_anon_key

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_BUCKET_NAME=gambih-files
# Dashboard → Storage → S3 Access Keys
SUPABASE_STORAGE_KEY=your_s3_access_key_id
SUPABASE_STORAGE_SECRET=your_s3_secret_access_key

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── JWT (optional overrides) ─────────────────────────────────────────────────
# ACCESS_TOKEN_LIFETIME_MINUTES=60
# REFRESH_TOKEN_LIFETIME_DAYS=7
