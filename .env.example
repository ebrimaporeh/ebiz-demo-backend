# ─── Django ───────────────────────────────────────────
SECRET_KEY=django-insecure-replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Supabase PostgreSQL (Transaction Pooler) ─────────
DB_NAME=postgres
DB_USER=postgres.neeuqoqxvmpbbskrxste
DB_PASSWORD=your_supabase_password
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=6543

# ─── Supabase Storage (S3-compatible) ─────────────────
# Get these from Supabase Dashboard → Storage → S3 Access Keys
SUPABASE_STORAGE_KEY=your_access_key_id
SUPABASE_STORAGE_SECRET=your_secret_access_key
SUPABASE_BUCKET_NAME=gambih-files
SUPABASE_STORAGE_URL=https://neeuqoqxvmpbbskrxste.supabase.co/storage/v1/s3

# ─── CORS ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

